{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "outDir": "./public/assets/javascript",
    "rootDir": "./src/frontend",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "sourceMap": true,
    "types": [],
    "noResolve": true
  },
  "include": ["src/frontend/**/*.ts"],
  "exclude": ["node_modules/**/*", "**/*.spec.ts", "**/*.d.ts"]
}
