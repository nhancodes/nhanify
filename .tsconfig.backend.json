{
  "extends": "./.tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist/backend",
    "rootDir": ".",
    "module": "commonjs",
    "target": "ES2020",
    "declaration": true,
    "noEmitOnError": true,
    "sourceMap": true,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true
  },
  "include": [
    "app.js",
    "routes/**/*.ts",
    "controllers/**/*.ts",
    "lib/**/*.js",
    "lib/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "src/frontend/**/*", "**/*.d.ts"]
}
